    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "fast-xml-parser": "^5.9.0",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
