  "scripts": {
    "deps:up": "powershell -ExecutionPolicy Bypass -File scripts/start-deps.ps1",
    "predev": "npm run deps:up",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "prisma db seed",
